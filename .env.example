# Copy to .env for local development
PORT=8787
TELEGRAM_BOT_TOKEN=123456:ABC...
SESSION_STORE=sqlite
SQLITE_PATH=./miniclaw.db
MODEL_PROVIDER=echo
AGENT_HISTORY_WINDOW=20
OPENAI_OAUTH_CLIENT_ID=your_openai_client_id
OPENAI_OAUTH_REDIRECT_URI=http://localhost:8787/oauth/callback
OPENAI_OAUTH_SCOPE=openid profile email offline_access
