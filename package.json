{
  "name": "miniclaw",
  "version": "0.4.0",
  "private": false,
  "description": "A minimal educational agent runtime inspired by OpenClaw",
  "type": "module",
  "scripts": {
    "dev": "tsx src/app.ts",
    "cli": "tsx src/cli.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/app.js",
    "test": "vitest run",
    "check": "npm run build && npm test"
  },
  "bin": {
    "miniclaw": "dist/cli.js"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "better-sqlite3": "^11.7.0",
    "fastify": "^5.8.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.10.1",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
